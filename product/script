const state = {
    mode: "focus",
    isRunning: false,
    timeLeft: 25 * 60,
    sessions: 0,
    currentToy: "squishy"
};

const focusInput = document.getElementById("focusInput");
const breakInput = document.getElementById("breakInput");
const timerMode = document.getElementById("timerMode");
const modeIndicator = document.getElementById("status");
const startBtn = document.getElementById("start");
const resetBtn = document.getElementById("reset");

let interval;

// Timer Stuff! (All Functions)
function updateDisplay() { // display time in min/sec
    let m = Math.floor(state.timeLeft / 60);
    let s = state.timeLeft % 60;
    timer.textContent =
        m.toString().padStart(2, "0") + ":" +
        s.toString().padStart(2, "0");
}

function startTimer() { 
    if (state.isRunning) {
        clearInterval(interval);
        state.isRunning = false;
        startBtn.innerHTML = "Start"
        return;
    }
    // toggle
    state.isRunning = true;
    startBtn.innerHTML = "Pause"

    interval = setInterval(() => {
        state.timeLeft--;

        if (state.timeLeft <= 0) switchMode();

        updateDisplay();
    }, 1000); // tick tick
}

function resetTimer() {
    clearInterval(interval);
    state.isRunning = false;
    state.mode = "focus";
    state.timeLeft = focusInput.value * 60;
    state.currentToy = "squishy";

    document.body.classList.remove("break");
    modeIndicator.innerHTML = "Focus";
    startBtn.innerHTML = "Start"
    updateDisplay();
}

function switchMode() {
    if (state.mode === "focus") {
        state.mode = "break";
        state.timeLeft = breakInput.value * 60;
        document.body.classList.add("break");
        modeIndicator.innerHTML = "Break";
        playSound(1) // high sound yay
        state.sessions++;

        if (state.sessions >= 5) {
            state.currentToy = "sand";
        }
        else if (state.sessions >= 2) {
            state.currentToy = "bubbles";
        }
        else {
            state.currentToy = "waves"
        } // decide which toy
    }
    else {
        state.mode = "focus";
        state.timeLeft = focusInput.value * 60;
        document.body.classList.remove("break");
        modeIndicator.innerHTML = "Focus";
        playSound(0) // low sound ahh
        state.currentToy = "squishy";
    }
}

// Audio Stuff! (Also all functions)
let audioCtx;

function playSound(high) {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    osc.connect(gain);
    gain.connect(audioCtx.destination); // spawn audio context
    
    osc.type = high ? 'triangle' : 'sine';
    osc.frequency.setValueAtTime(high ? 880 : 440, audioCtx.currentTime);
    gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.5);
    // form sound
    osc.start();
    osc.stop(audioCtx.currentTime + 0.5); // play sound
}

// Canvas Stuff! (real work)
const canvas = document.getElementById("canvas"); // make the canvas drawable
const ctx = canvas.getContext("2d");

function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
}
window.addEventListener("resize", resize);
resize();

let mouse = { x: 0, y: 0 };
let isHolding = false; // handle mouse existence

canvas.addEventListener("mousemove", (e) => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
});

canvas.addEventListener("mousedown", () => {
    isHolding = true;
    if (state.currentToy === "squishy") {
        squishy.target = 20;
    }
});

canvas.addEventListener("mouseup", () => {
    isHolding = false;
});

canvas.addEventListener("mouseleave", () => {
    isHolding = false;
});

// Toys! (all functions in objects)
let bubbles = [];
let sand = [];
let waveOffset = 0;
let squishy = { x: 300, y: 300, size: 120, target: 60 };

// An object can contain functions; they need not be associative pairs
const toys = {
    bubbles: {
        update() {
            bubbles.forEach(b => b.y -= b.speed);
            bubbles = bubbles.filter(b => b.y > -50); // go up
        },
        draw() {
            bubbles.forEach(b => {
                ctx.beginPath();
                ctx.arc(b.x, b.y, b.size, 0, Math.PI * 2);
                ctx.stroke(); // draw a circle everywhwere there's a bubble
            });
        },
        click(e) {
            bubbles.push({
                x: e.clientX,
                y: e.clientY,
                size: Math.random() * 20 + 10,
                speed: Math.random() + 0.5
            }); // make new bubble
        }
    },

    sand: {
        update() {
            for (let i = sand.length - 1; i >= 0; i--) {
                let p = sand[i];

                // try move down
                let below = sand.find(s => s.x === p.x && s.y === p.y + 2);

                if (!below) {
                    p.y += 2;
                } else {
                    // try slide left/right
                    let left = sand.find(s => s.x === p.x - 2 && s.y === p.y + 2);
                    let right = sand.find(s => s.x === p.x + 2 && s.y === p.y + 2);

                    if (!left) {
                        p.x -= 2;
                        p.y += 2;
                    } else if (!right) {
                        p.x += 2;
                        p.y += 2;
                    }
                }

                // check if touching floor rn
                let atFloor = p.y + 2 >= canvas.height;

                if (!below && !atFloor) {
                    p.y += 2;
                } else {
                    let left = sand.find(s => s.x === p.x - 2 && s.y === p.y + 2);
                    let right = sand.find(s => s.x === p.x + 2 && s.y === p.y + 2);

                    if (!left && !atFloor) {
                        p.x -= 2;
                        p.y += 2;
                    } else if (!right && !atFloor) {
                        p.x += 2;
                        p.y += 2;
                    }

                }
            }
        },

        draw() {
            ctx.fillStyle = "tan"; // speck each grain
            sand.forEach(p => {
                ctx.fillRect(p.x, p.y, 2, 2);
            });
        },

        click(e) {
            for (let i = 0; i < 20; i++) {
                sand.push({ // make new grain
                    x: Math.floor(e.clientX / 2) * 2,
                    y: Math.floor(e.clientY / 2) * 2
                });
            }
        }
    },

    waves: {
        update() { waveOffset += 0.05; }, // change sin
        draw() {
            ctx.beginPath();
            for (let x = 0; x < canvas.width; x++) {
                let y = canvas.height/2 + Math.sin(x*0.01 + waveOffset)*50; // draw sine wave
                ctx.lineTo(x, y);
            }
            ctx.stroke();
        }
    },

    squishy: {
        update() {
            // auto-expand when not holding
            if (!isHolding) {
                squishy.target = 60;
            }
            squishy.size += (squishy.target - squishy.size) * 0.2;

            // cursor pull
            if (state.mode === "focus") {
                let dx = mouse.x - squishy.x;
                let dy = mouse.y - squishy.y;

                squishy.x += dx * 0.05;
                squishy.y += dy * 0.05;
            }
        },
        draw() {
            ctx.beginPath();
            ctx.arc(squishy.x, squishy.y, squishy.size, 0, Math.PI * 2); // draw circle
            ctx.fillStyle = "#aaa";
            ctx.fill(); // fill circle
        },
        click(e) {
            squishy.x = e.clientX;
            squishy.y = e.clientY;
            squishy.target = 30; // go
        },
        release() {
            squishy.target = 60;
        }
    }
};

// Stuff that actually Happens and Responds
canvas.addEventListener("click", (e) => {
    toys[state.currentToy]?.click?.(e);
});

canvas.addEventListener("mouseup", () => {
    toys[state.currentToy]?.release?.();
});

function loop() { // Check wassup
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    toys[state.currentToy]?.update();
    toys[state.currentToy]?.draw();

    drawTimerVisual();

    requestAnimationFrame(loop);
}// Updates timer and toys
loop();

// timer eye
function drawTimerVisual() {
    let total = (state.mode === "focus" ? focusInput.value : breakInput.value) * 60;
    let progress = state.timeLeft / total;

    if (timerMode.value === "ring") {
        ctx.beginPath();
        ctx.arc(canvas.width-80, 80, 50, 0, Math.PI*2);
        ctx.strokeStyle = "#333";
        ctx.stroke(); // draw circle

        ctx.beginPath();
        ctx.arc(canvas.width-80, 80, 50, -Math.PI/2,
            -Math.PI/2 + Math.PI*2*progress); // draw not done part
        ctx.strokeStyle = "white";
        ctx.stroke();
    }

    if (timerMode.value === "bar") {
        ctx.fillStyle = "#333";
        ctx.fillRect(50, canvas.height-50, canvas.width-100, 20); // make full bar

        ctx.fillStyle = "white";
        ctx.fillRect(50, canvas.height-50, (canvas.width-100)*progress, 20); // fill bar
    }
}

const timer = document.getElementById("timer");
document.getElementById("start").onclick = startTimer;
document.getElementById("reset").onclick = resetTimer;
// make sure buttons do what they should
updateDisplay();
